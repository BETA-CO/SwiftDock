<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_dark"
    android:padding="24dp"
    android:layout_gravity="center">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Update Available"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Scrollable Changelog Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E5E7EB"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2"
            android:text="A new version is available."/>
    </ScrollView>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Later Button (Flat / Ghost style) -->
        <Button
            android:id="@+id/btn_dialog_later"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Later"
            android:textColor="#A1A1AA"
            android:background="?android:attr/selectableItemBackground"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="12dp"/>

        <!-- Update Now Button (Solid / Primary style) -->
        <Button
            android:id="@+id/btn_dialog_update"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Update Now"
            android:textColor="#121216"
            android:background="@drawable/bg_btn_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>
    </LinearLayout>
</LinearLayout>
