<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".FirstFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp">

            <!-- FrameLayout container centering all step layouts vertically/horizontally on screen -->
            <FrameLayout
                android:id="@+id/card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- STEP 1: NAME YOUR PHONE (Horizontal split with branding on left) -->
                <LinearLayout
                    android:id="@+id/layout_step1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5"
                    android:layout_gravity="center"
                    android:visibility="visible">

                    <!-- Left Branding Panel (Only in Step 1) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingStart="48dp"
                        android:paddingEnd="32dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SwiftDock"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wireless deck for your computer."
                            android:textColor="#8E8E93"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp"
                            android:lineSpacingMultiplier="1.2" />

                        <View
                            android:layout_width="48dp"
                            android:layout_height="2dp"
                            android:background="#FFFFFF"
                            android:layout_marginTop="24dp" />
                    </LinearLayout>

                    <!-- Right Name Entry Panel -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="48dp"
                        android:paddingTop="24dp"
                        android:paddingBottom="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Name your device"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="This name will appear on your computer."
                            android:textColor="#8E8E93"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/edit_mobile_name"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="24dp"
                            android:background="@drawable/input_background"
                            android:hint="e.g. My Phone"
                            android:inputType="text"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#5A5A5E"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btn_step1_next"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="24dp"
                            android:background="@drawable/button_primary"
                            app:backgroundTint="@null"
                            android:text="Continue"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_step1_back"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="8dp"
                            android:background="@android:color/transparent"
                            app:backgroundTint="@null"
                            android:text="Back to Saved Connection"
                            android:textAllCaps="false"
                            android:textColor="#8E8E93"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- STEP 2: PIN ENTRY (Centered Split layout, NO branding text) -->
                <LinearLayout
                    android:id="@+id/layout_step2"
                    android:layout_width="580dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <!-- Left side: Status, PIN entry indicators & actions -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="24dp"
                        android:layout_gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enter pairing PIN"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_discovery_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Searching for your computer..."
                            android:textColor="#8E8E93"
                            android:textSize="13sp" />

                        <!-- Passcode digit Indicators Layout -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="24dp"
                            android:layout_marginBottom="24dp">

                            <TextView
                                android:id="@+id/pin_digit1"
                                android:layout_width="40dp"
                                android:layout_height="46dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/input_background"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/pin_digit2"
                                android:layout_width="40dp"
                                android:layout_height="46dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/input_background"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/pin_digit3"
                                android:layout_width="40dp"
                                android:layout_height="46dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/input_background"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/pin_digit4"
                                android:layout_width="40dp"
                                android:layout_height="46dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/input_background"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_step2_connect"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/button_primary"
                            app:backgroundTint="@null"
                            android:text="Connect"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:enabled="false" />

                        <Button
                            android:id="@+id/btn_step2_back"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="4dp"
                            android:background="@android:color/transparent"
                            app:backgroundTint="@null"
                            android:text="Back"
                            android:textAllCaps="false"
                            android:textColor="#8E8E93"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Right side: The 3x4 numeric keypad (using TextView to avoid clipping) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_gravity="center_vertical"
                        android:paddingStart="24dp">

                        <!-- Keypad Row 1 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/keypad_1"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_2"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_3"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <!-- Keypad Row 2 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/keypad_4"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="4"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_5"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="5"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_6"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="6"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <!-- Keypad Row 3 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/keypad_7"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="7"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_8"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="8"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_9"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="9"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <!-- Keypad Row 4 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/keypad_clear"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="C"
                                android:textColor="#FF453A"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_0"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <TextView
                                android:id="@+id/keypad_backspace"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_margin="4dp"
                                android:background="@drawable/keypad_button_bg"
                                android:gravity="center"
                                android:text="⌫"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- STEP 3: CONNECTION SUCCESS (Fullscreen Center) -->
                <LinearLayout
                    android:id="@+id/layout_step3"
                    android:layout_width="440dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_check_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Connected"
                        android:textColor="#10B981"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_success_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Click 'Next' on your computer to continue."
                        android:textColor="#8E8E93"
                        android:textSize="14sp" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:indeterminate="true"
                        android:indeterminateTint="#10B981" />
                </LinearLayout>

                <!-- RECONNECTING STATE (Fullscreen Center) -->
                <LinearLayout
                    android:id="@+id/layout_reconnecting"
                    android:layout_width="440dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progress_reconnect"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="#FFFFFF" />

                    <TextView
                        android:id="@+id/tv_reconnect_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Reconnecting..."
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_reconnect_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Looking for your paired computer."
                        android:textColor="#8E8E93"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btn_retry_reconnect"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/button_primary"
                        app:backgroundTint="@null"
                        android:text="Retry"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btn_cancel_reconnect"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        app:backgroundTint="@null"
                        android:text="Cancel &amp; Unpair"
                        android:textAllCaps="false"
                        android:textColor="#EF4444"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- RECONNECT OPTIONS (Horizontal split with branding on left) -->
                <LinearLayout
                    android:id="@+id/layout_reconnect_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <!-- Left Branding Panel (Same as Step 1) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingStart="48dp"
                        android:paddingEnd="32dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SwiftDock"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wireless deck for your computer."
                            android:textColor="#8E8E93"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp"
                            android:lineSpacingMultiplier="1.2" />

                        <View
                            android:layout_width="48dp"
                            android:layout_height="2dp"
                            android:background="#FFFFFF"
                            android:layout_marginTop="24dp" />
                    </LinearLayout>

                    <!-- Right Reconnect Choices Panel -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="48dp"
                        android:paddingTop="24dp"
                        android:paddingBottom="24dp">

                        <TextView
                            android:id="@+id/tv_reconnect_options_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reconnect Device"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_reconnect_options_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Would you like to connect to your previously paired computer?"
                            android:textColor="#8E8E93"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btn_connect_old"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="28dp"
                            android:background="@drawable/button_primary"
                            app:backgroundTint="@null"
                            android:text="Connect to Computer"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_pair_new"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/button_secondary"
                            app:backgroundTint="@null"
                            android:text="Pair New Device"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>