<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".FirstFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp">

            <!-- FrameLayout container centering all step layouts vertically/horizontally on screen -->
            <FrameLayout
                android:id="@+id/card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- RECONNECTING STATE (Fullscreen Center) -->
                <LinearLayout
                    android:id="@+id/layout_reconnecting"
                    android:layout_width="440dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progress_reconnect"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="#FFFFFF" />

                    <TextView
                        android:id="@+id/tv_reconnect_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Reconnecting..."
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_reconnect_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Looking for your paired computer."
                        android:textColor="#8E8E93"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btn_retry_reconnect"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/button_primary"
                        app:backgroundTint="@null"
                        android:text="Retry"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btn_cancel_reconnect"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        app:backgroundTint="@null"
                        android:text="Cancel &amp; Unpair"
                        android:textAllCaps="false"
                        android:textColor="#EF4444"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- RECONNECT OPTIONS (Horizontal split with branding on left) -->
                <LinearLayout
                    android:id="@+id/layout_reconnect_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <!-- Left Branding Panel (Same as Step 1) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingStart="48dp"
                        android:paddingEnd="32dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SwiftDock"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wireless deck for your computer."
                            android:textColor="#8E8E93"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp"
                            android:lineSpacingMultiplier="1.2" />

                        <View
                            android:layout_width="48dp"
                            android:layout_height="2dp"
                            android:background="#FFFFFF"
                            android:layout_marginTop="24dp" />
                    </LinearLayout>

                    <!-- Right Reconnect Choices Panel -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="48dp"
                        android:paddingTop="24dp"
                        android:paddingBottom="24dp">

                        <TextView
                            android:id="@+id/tv_reconnect_options_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reconnect Device"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_reconnect_options_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Would you like to connect to your previously paired computer?"
                            android:textColor="#8E8E93"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btn_connect_old"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="28dp"
                            android:background="@drawable/button_primary"
                            app:backgroundTint="@null"
                            android:text="Connect to Computer"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_pair_new"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/button_secondary"
                            app:backgroundTint="@null"
                            android:text="Pair New Device"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>